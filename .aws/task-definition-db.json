{
  "containerDefinitions": [
    {
      "name": "data-container",
      "image": "193419803239.dkr.ecr.us-east-1.amazonaws.com/tienda-perrito-data:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 3306,
          "hostPort": 3306,
          "protocol": "tcp",
          "name": "data-container-3306-tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "MYSQL_PASSWORD",
          "value": "alumno123"
        },
        {
          "name": "MYSQL_ROOT_PASSWORD",
          "value": "admin123"
        },
        {
          "name": "MYSQL_USER",
          "value": "alumno"
        },
        {
          "name": "MYSQL_DATABASE",
          "value": "tienda_perritos"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tarea-data",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "family": "tarea-data",
  "taskRoleArn": "arn:aws:iam::193419803239:role/LabRole",
  "executionRoleArn": "arn:aws:iam::193419803239:role/LabRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
